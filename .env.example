# ─────────────────────────────────────────────────────────────────────────────
# Red Team Attack Simulator — environment configuration
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI (attack generator + GPT target) ── REQUIRED for most modes ──
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-06-01

# ── Anthropic (Claude target + LLM judge) ── REQUIRED ──
ANTHROPIC_API_KEY=
# Model under test when the target is "claude" (override per engagement):
CLAUDE_TARGET_MODEL=claude-sonnet-4-5
# Model used to judge whether an attack succeeded (keep this strong):
JUDGE_MODEL=claude-opus-4-8

# ── Amazon Bedrock (optional target + Guardrails) ──
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ── Azure AI Search (optional — RAG-powered attack research) ──
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=

# ── Simulator tunables (optional — sensible defaults shown) ──
MAX_WORKERS=4              # concurrent tests in a batch (bounded rate limiting)
MAX_RETRIES=3              # SDK auto-retry attempts on 429/5xx
REQUEST_TIMEOUT=60         # per-request timeout, seconds
DEFAULT_TEMPERATURE=0.9    # attack-generation creativity
RESULTS_DIR=results        # where logs/reports are written

# ── Diagnostics (optional) ──
# REDTEAM_LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
# REDTEAM_DEBUG=1          # shorthand for DEBUG-level diagnostics
